{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ApiManagerUrlOptions": {
    "BrasilApi": {
      "BaseUrl": "https://brasilapi.com.br/api",
      "DadosCnpj": "/cnpj/v1/{0}",
      "DadosCep": "/cep/v2/{0}"
    },
    "ViaCep": {
      "BaseUrl": "https://viacep.com.br/ws",
      "DadosCep": "/{0}/json/"
    }
  },
  "InfrasctructureOptions": {
    "ResilienciaConfig": {
      "Services": {
        "ServicePrincipal": "BrasilApi",
        "ServiceFallback": "ViaCep"
      },
      "RetryCount": 2,
      "CircuitBreakerFailureRatio": 0.5,
      "CircuitBreakerMinimumThroughput": 3,
      "CircuitBreakerSamplingDuration": 20,
      "CircuitBreakerBreakDuration": 30
    },
    "SerilogConfig": {
      "Path": "D:\\repos\\TL.Shipay.Project\\FileLogs"
    }
  }
}

